<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="id.xxx.xposed.module">

    <permission
        android:name="${applicationId}.READ_DATABASE"
        android:protectionLevel="normal" />
    <permission
        android:name="${applicationId}.WRITE_DATABASE"
        android:protectionLevel="normal" />

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.XposedModule"
        tools:ignore="AllowBackup">
        <activity android:name="id.xxx.xposed.ui.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="id.xxx.xposed.provider.AppContentProvider"
            android:authorities="${applicationId}"
            android:enabled="true"
            android:exported="true" />

        <!-- START XPOSED META_DATA -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Example Description" />
        <meta-data
            android:name="xposedminversion"
            android:value="53" />
        <!-- END XPOSED META_DATA -->

    </application>

</manifest>